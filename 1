-- 創建 UI 元素
function CustomUI.new(class, props, children)
    local obj = Instance.new(class)
    
    for k, v in pairs(props or {}) do
        pcall(function()
            obj[k] = v
        end)
    end
    
    for _, child in pairs(children or {}) do
        if child then
            child.Parent = obj
        end
    end
    
    return obj
end

-- 創建帶圓角的框架
function CustomUI.newRoundFrame(radius, props, children)
    local frame = CustomUI.new("ImageLabel", {
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ScaleType = "Slice",
        SliceCenter = Rect.new(radius, radius, radius, radius),
        SliceScale = 1,
    }, {
        CustomUI.new("UICorner", {
            CornerRadius = UDim.new(0, radius)
        })
    })
    
    for k, v in pairs(props or {}) do
        pcall(function()
            frame[k] = v
        end)
    end
    
    for _, child in pairs(children or {}) do
        child.Parent = frame
    end
    
    return frame
end

-- 創建通知
function CustomUI:Notify(config)
    config = config or {}
    local theme = self.Themes[self.CurrentTheme or "Dark"]
    
    local notification = CustomUI.new("Frame", {
        Size = UDim2.new(0, 300, 0, 0),
        Position = UDim2.new(1, -320, 1, -100),
        BackgroundColor3 = theme.Surface,
        BackgroundTransparency = 0.1,
        Parent = self.NotificationHolder
    }, {
        CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 8) }),
        CustomUI.new("Frame", {
            Size = UDim2.new(1, 0, 0, 4),
            BackgroundColor3 = theme.Primary,
            Position = UDim2.new(0, 0, 0, 0)
        }, {
            CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 8) })
        })
    })
    
    -- 標題
    if config.Title then
        CustomUI.new("TextLabel", {
            Size = UDim2.new(1, -24, 0, 20),
            Position = UDim2.new(0, 12, 0, 12),
            BackgroundTransparency = 1,
            Text = config.Title,
            TextColor3 = theme.Text,
            TextSize = 16,
            Font = Enum.Font.GothamSemibold,
            TextXAlignment = "Left",
            Parent = notification
        })
    end
    
    -- 內容
    if config.Content then
        CustomUI.new("TextLabel", {
            Size = UDim2.new(1, -24, 0, 36),
            Position = UDim2.new(0, 12, 0, config.Title and 32 or 12),
            BackgroundTransparency = 1,
            Text = config.Content,
            TextColor3 = theme.TextSecondary,
            TextSize = 14,
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            TextXAlignment = "Left",
            Parent = notification
        })
    end
    
    notification.Size = UDim2.new(0, 300, 0, (config.Title and 20 or 0) + (config.Content and 48 or 0) + 16)
    
    tween(notification, 0.3, {
        Position = UDim2.new(1, -320, 1, -100 - notification.AbsoluteSize.Y)
    }):Play()
    
    if config.Duration then
        task.wait(config.Duration)
        tween(notification, 0.3, {
            Position = UDim2.new(1, -320, 1, -100)
        }):Play()
        task.wait(0.3)
        notification:Destroy()
    end
    
    return notification
end

