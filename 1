-- 創建通知
function CustomUI:Notify(config)
    config = config or {}
    local theme = self.Themes[self.CurrentTheme or "Dark"]
    
    if not self.NotificationHolder then
        self.NotificationHolder = CustomUI.new("Frame", {
            Name = "Notifications",
            Size = UDim2.new(0, 320, 1, -20),
            Position = UDim2.new(1, -330, 0, 10),
            BackgroundTransparency = 1,
            Parent = self.ScreenGui
        })
    end
    
    local notification = CustomUI.newRoundFrame(10, "Squircle", {
        Size = UDim2.new(0, 300, 0, 0),
        Position = UDim2.new(1, -320, 1, -100),
        ImageColor3 = theme.Dialog,
        ImageTransparency = 0,
        Parent = self.NotificationHolder
    })
    
    if config.Title then
        CustomUI.new("TextLabel", {
            Size = UDim2.new(1, -24, 0, 20),
            Position = UDim2.new(0, 12, 0, 12),
            BackgroundTransparency = 1,
            Text = config.Title,
            TextColor3 = theme.Text,
            TextSize = 16,
            Font = Enum.Font.GothamSemibold,
            TextXAlignment = "Left",
            Parent = notification
        })
    end
    
    if config.Content then
        CustomUI.new("TextLabel", {
            Size = UDim2.new(1, -24, 0, 36),
            Position = UDim2.new(0, 12, 0, config.Title and 32 or 12),
            BackgroundTransparency = 1,
            Text = config.Content,
            TextColor3 = theme.Placeholder,
            TextSize = 14,
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            TextXAlignment = "Left",
            Parent = notification
        })
    end
    
    local height = (config.Title and 20 or 0) + (config.Content and 48 or 0) + 16
    notification.Size = UDim2.new(0, 300, 0, height)
    
    tween(notification, 0.3, {
        Position = UDim2.new(1, -320, 1, -100 - height - 10)
    }):Play()
    
    if config.Duration then
        task.wait(config.Duration)
        tween(notification, 0.3, {
            Position = UDim2.new(1, -320, 1, -100)
        }):Play()
        task.wait(0.3)
        notification:Destroy()
    end
    
    return notification
end

