				SliderFrame.Size = UDim2.new(1, 0, 0, 45)
				
				local SliderCorner = Instance.new("UICorner")
				SliderCorner.CornerRadius = UDim.new(0, 8)
				SliderCorner.Parent = SliderFrame
				
				local SliderText = Instance.new("TextLabel")
				SliderText.Parent = SliderFrame
				SliderText.BackgroundTransparency = 1
				SliderText.Size = UDim2.new(1, -80, 0, 20)
				SliderText.Position = UDim2.new(0, 10, 0, 5)
				SliderText.Font = Enum.Font.GothamSemibold
				SliderText.Text = text
				SliderText.TextColor3 = colors.Text
				SliderText.TextSize = 14
				SliderText.TextXAlignment = Enum.TextXAlignment.Left
				
				local ValueLabel = Instance.new("TextLabel")
				ValueLabel.Parent = SliderFrame
				ValueLabel.BackgroundColor3 = colors.Surface
				ValueLabel.BackgroundTransparency = 0.5
				ValueLabel.BorderSizePixel = 0
				ValueLabel.Size = UDim2.new(0, 50, 0, 24)
				ValueLabel.Position = UDim2.new(1, -60, 0, 3)
				ValueLabel.Font = Enum.Font.GothamBold
				ValueLabel.Text = tostring(value)
				ValueLabel.TextColor3 = colors.PrimaryLight
				ValueLabel.TextSize = 14
				
				local ValueCorner = Instance.new("UICorner")
				ValueCorner.CornerRadius = UDim.new(0, 6)
				ValueCorner.Parent = ValueLabel
				
				local SliderBar = Instance.new("Frame")
				SliderBar.Parent = SliderFrame
				SliderBar.BackgroundColor3 = colors.Surface
				SliderBar.BorderSizePixel = 0
				SliderBar.Size = UDim2.new(1, -20, 0, 6)
				SliderBar.Position = UDim2.new(0, 10, 0, 32)
				
				local BarCorner = Instance.new("UICorner")
				BarCorner.CornerRadius = UDim.new(1, 0)
				BarCorner.Parent = SliderBar
				
				local FillBar = Instance.new("Frame")
				FillBar.Parent = SliderBar
				FillBar.BackgroundColor3 = colors.Primary
				FillBar.BorderSizePixel = 0
				FillBar.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
				
				local FillCorner = Instance.new("UICorner")
				FillCorner.CornerRadius = UDim.new(1, 0)
				FillCorner.Parent = FillBar
				
				local Knob = Instance.new("Frame")
				Knob.Parent = FillBar
				Knob.BackgroundColor3 = colors.Text
				Knob.BorderSizePixel = 0
				Knob.Size = UDim2.new(0, 12, 0, 12)
				Knob.Position = UDim2.new(1, -6, 0.5, -6)
				
				local KnobCorner = Instance.new("UICorner")
				KnobCorner.CornerRadius = UDim.new(1, 0)
				KnobCorner.Parent = Knob
				
				local function updateValue(input)
					local percent = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
					value = math.floor(min + (max - min) * percent)
					ValueLabel.Text = tostring(value)
					FillBar.Size = UDim2.new(percent, 0, 1, 0)
					library.flags[flag] = value
					if callback then callback(value) end
				end
				
				local dragging = false
				
				SliderBar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						updateValue(input)
						dragging = true
					end
				end)
				
				userInputService.InputChanged:Connect(function(input)
					if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
						updateValue(input)
					end
				end)
				
				userInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = false
					end
				end)
				
				return {
					Set = function(_, newValue)
						value = math.clamp(newValue, min, max)
						local percent = (value - min) / (max - min)
						ValueLabel.Text = tostring(value)
						FillBar.Size = UDim2.new(percent, 0, 1, 0)
						library.flags[flag] = value
						if callback then callback(value) end
					end
				}
			end
			
			return section
		end
		
		return tab
	end
	
	return window
end

return library
