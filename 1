            Position = UDim2.new(0, 4, 0, 0),
            BackgroundColor3 = theme.Surface,
            AutoButtonColor = false,
            Text = "",
            Parent = self.Tabs.List
        }, {
            CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 8) })
        })
        
        -- 標籤圖標（如果有）
