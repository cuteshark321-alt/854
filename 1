            Size = UDim2.new(1, tab.Icon and -38 or -16, 1, 0),
            Position = UDim2.new(0, tab.Icon and 36 or 8, 0, 0),
            BackgroundTransparency = 1,
            Text = tab.Name,
            TextColor3 = theme.TextSecondary,
            TextSize = 15,
            Font = Enum.Font.Gotham,
            TextXAlignment = "Left",
            Parent = button
        })
        
        -- 創建標籤內容框架
        local content = CustomUI.new("ScrollingFrame", {
            Name = "TabContent_" .. tab.Name,
            Size = UDim2.new(1, -32, 1, -32),
            Position = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 6,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = "Y",
            Parent = self.Content
        }, {
            CustomUI.new("UIListLayout", {
                Padding = UDim.new(0, 8),
                SortOrder = "LayoutOrder"
            }),
            CustomUI.new("UIPadding", {
                PaddingTop = UDim.new(0, 8),
                PaddingBottom = UDim.new(0, 8)
            })
        })
        
        tab.Content = content
        tab.Button = button
        tab.Label = label
        
        -- 按鈕點擊事件
        button.MouseButton1Click:Connect(function()
            -- 取消選中所有標籤
            for _, btn in pairs(self.TabButtons) do
                btn.Button.BackgroundColor3 = theme.Surface
                btn.Label.TextColor3 = theme.TextSecondary
                if btn.IconObj then
                    btn.IconObj.ImageColor3 = theme.TextSecondary
                end
                btn.Content.Visible = false
            end
            
            -- 選中當前標籤
            button.BackgroundColor3 = theme.Primary
            label.TextColor3 = theme.Text
            if tab.IconObj then
                tab.IconObj.ImageColor3 = theme.Text
            end
            content.Visible = true
            self.CurrentTab = tab
        end)
        
        table.insert(self.TabButtons, tab)
        
        -- 如果是第一個標籤，自動選中
        if #self.TabButtons == 1 then
            button.BackgroundColor3 = theme.Primary
            label.TextColor3 = theme.Text
            if tab.IconObj then
                tab.IconObj.ImageColor3 = theme.Text
            end
            content.Visible = true
            self.CurrentTab = tab
        end
        
        -- 添加元素的方法
        function tab:AddElement(elementType, config)
            config = config or {}
            
            local element
            
            if elementType == "Button" then
                -- 按鈕元素
                element = CustomUI.new("TextButton", {
                    Size = UDim2.new(1, 0, 0, 40),
                    BackgroundColor3 = theme.Primary,
                    AutoButtonColor = false,
                    Text = "",
                    Parent = content
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 8) }),
                    CustomUI.new("TextLabel", {
                        Size = UDim2.new(1, -32, 1, 0),
                        Position = UDim2.new(0, 16, 0, 0),
                        BackgroundTransparency = 1,
                        Text = config.Title or "Button",
                        TextColor3 = theme.Text,
                        TextSize = 16,
                        Font = Enum.Font.Gotham,
                        TextXAlignment = "Left"
                    })
                })
                
                element.MouseButton1Click:Connect(function()
                    if config.Callback then
                        config.Callback()
                    end
                end)
                
            elseif elementType == "Toggle" then
                -- 切換開關元素
                local value = config.Value or false
                
                element = CustomUI.new("Frame", {
                    Size = UDim2.new(1, 0, 0, 40),
                    BackgroundTransparency = 1,
                    Parent = content
                })
                
                -- 標題
                local title = CustomUI.new("TextLabel", {
                    Size = UDim2.new(1, -60, 1, 0),
                    Position = UDim2.new(0, 16, 0, 0),
                    BackgroundTransparency = 1,
                    Text = config.Title or "Toggle",
                    TextColor3 = theme.Text,
                    TextSize = 16,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = "Left",
                    Parent = element
                })
                
                -- 開關按鈕
                local toggle = CustomUI.new("Frame", {
                    Size = UDim2.new(0, 44, 0, 24),
                    Position = UDim2.new(1, -60, 0.5, -12),
                    BackgroundColor3 = value and theme.Success or theme.Border,
                    Parent = element
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
                })
                
                local knob = CustomUI.new("Frame", {
                    Size = UDim2.new(0, 20, 0, 20),
                    Position = UDim2.new(value and 1 or 0, value and -22 or 2, 0.5, -10),
                    BackgroundColor3 = theme.Text,
                    Parent = toggle
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
                })
                
                local button = CustomUI.new("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = toggle
                })
                
                button.MouseButton1Click:Connect(function()
                    value = not value
                    
                    toggle.BackgroundColor3 = value and theme.Success or theme.Border
                    tween(knob, 0.2, {
                        Position = UDim2.new(value and 1 or 0, value and -22 or 2, 0.5, -10)
                    }):Play()
                    
                    if config.Callback then
                        config.Callback(value)
                    end
                end)
                
                element.Set = function(_, newValue)
                    value = newValue
                    toggle.BackgroundColor3 = value and theme.Success or theme.Border
                    knob.Position = UDim2.new(value and 1 or 0, value and -22 or 2, 0.5, -10)
                end
                
            elseif elementType == "Slider" then
                -- 滑塊元素
                local min = config.Min or 0
                local max = config.Max or 100
                local defaultValue = config.Default or min
                local value = defaultValue
                
                element = CustomUI.new("Frame", {
                    Size = UDim2.new(1, 0, 0, 50),
                    BackgroundTransparency = 1,
                    Parent = content
                })
                
                -- 標題
                local title = CustomUI.new("TextLabel", {
                    Size = UDim2.new(1, -80, 0, 20),
                    Position = UDim2.new(0, 16, 0, 4),
                    BackgroundTransparency = 1,
                    Text = config.Title or "Slider",
                    TextColor3 = theme.Text,
                    TextSize = 16,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = "Left",
                    Parent = element
                })
                
                -- 數值顯示
                local valueLabel = CustomUI.new("TextLabel", {
                    Size = UDim2.new(0, 60, 0, 20),
                    Position = UDim2.new(1, -76, 0, 4),
                    BackgroundTransparency = 1,
                    Text = tostring(defaultValue),
                    TextColor3 = theme.Primary,
                    TextSize = 14,
                    Font = Enum.Font.GothamBold,
                    Parent = element
                })
                
                -- 滑塊軌道
                local track = CustomUI.new("Frame", {
                    Size = UDim2.new(1, -32, 0, 4),
                    Position = UDim2.new(0, 16, 0, 34),
                    BackgroundColor3 = theme.Border,
                    Parent = element
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
                })
                
                -- 滑塊填充
                local fill = CustomUI.new("Frame", {
                    Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = theme.Primary,
                    Parent = track
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
                })
                
                -- 滑塊手柄
                local knob = CustomUI.new("Frame", {
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new((value - min) / (max - min), -8, 0.5, -8),
                    BackgroundColor3 = theme.Text,
                    Parent = track
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
                })
                
                local dragging = false
                
                knob.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                    end
                end)
                
                RunService.RenderStepped:Connect(function()
                    if dragging then
                        local pos = UserInputService:GetMouseLocation()
                        local trackPos = track.AbsolutePosition
                        local trackSize = track.AbsoluteSize
                        
                        local percent = math.clamp((pos.X - trackPos.X) / trackSize.X, 0, 1)
                        value = min + (max - min) * percent
                        if config.Step then
                            value = math.floor(value / config.Step + 0.5) * config.Step
                            percent = (value - min) / (max - min)
                        end
                        
                        fill.Size = UDim2.new(percent, 0, 1, 0)
                        knob.Position = UDim2.new(percent, -8, 0.5, -8)
                        valueLabel.Text = tostring(math.floor(value * 100) / 100)
                        
                        if config.Callback then
                            config.Callback(value)
                        end
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                element.Set = function(_, newValue)
                    value = newValue
                    local percent = (value - min) / (max - min)
                    fill.Size = UDim2.new(percent, 0, 1, 0)
                    knob.Position = UDim2.new(percent, -8, 0.5, -8)
                    valueLabel.Text = tostring(math.floor(value * 100) / 100)
                end
                
            elseif elementType == "Dropdown" then
                -- 下拉選單
                local values = config.Values or {}
                local value = config.Value or (values[1] or "")
                
                element = CustomUI.new("Frame", {
                    Size = UDim2.new(1, 0, 0, 40),
                    BackgroundTransparency = 1,
                    Parent = content
                })
                
                -- 標題
                local title = CustomUI.new("TextLabel", {
                    Size = UDim2.new(1, -120, 1, 0),
                    Position = UDim2.new(0, 16, 0, 0),
                    BackgroundTransparency = 1,
                    Text = config.Title or "Dropdown",
                    TextColor3 = theme.Text,
                    TextSize = 16,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = "Left",
                    Parent = element
                })
                
                -- 下拉框
                local box = CustomUI.new("TextButton", {
                    Size = UDim2.new(0, 100, 0, 32),
                    Position = UDim2.new(1, -116, 0.5, -16),
                    BackgroundColor3 = theme.Surface,
                    AutoButtonColor = false,
                    Text = "",
                    Parent = element
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 6) })
                })
                
                -- 選中值
                local selectedLabel = CustomUI.new("TextLabel", {
                    Size = UDim2.new(1, -20, 1, 0),
                    Position = UDim2.new(0, 8, 0, 0),
                    BackgroundTransparency = 1,
                    Text = value,
                    TextColor3 = theme.Text,
                    TextSize = 14,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = "Left",
                    Parent = box
                })
                
                -- 箭頭圖標
                local arrow = CustomUI.new("ImageLabel", {
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(1, -20, 0.5, -8),
                    BackgroundTransparency = 1,
                    Image = "rbxassetid://6031090990",
                    ImageColor3 = theme.TextSecondary,
                    Parent = box
                })
                
                -- 下拉菜單
                local menu = CustomUI.new("Frame", {
                    Size = UDim2.new(0, 100, 0, 0),
                    Position = UDim2.new(1, -116, 1, 4),
                    BackgroundColor3 = theme.Surface,
                    Visible = false,
                    ClipsDescendants = true,
                    Parent = element,
                    ZIndex = 10
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 6) }),
                    CustomUI.new("UIListLayout", {
                        Padding = UDim.new(0, 2),
                        SortOrder = "LayoutOrder"
                    }),
                    CustomUI.new("UIPadding", {
                        PaddingTop = UDim.new(0, 4),
                        PaddingBottom = UDim.new(0, 4)
                    })
                })
                
                -- 創建選項
                local optionButtons = {}
                local function refreshOptions(newValues)
                    -- 清除舊選項
                    for _, btn in pairs(optionButtons) do
                        btn:Destroy()
                    end
                    optionButtons = {}
                    
                    -- 添加新選項
                    for _, val in ipairs(newValues) do
                        local option = CustomUI.new("TextButton", {
                            Size = UDim2.new(1, -8, 0, 30),
                            Position = UDim2.new(0, 4, 0, 0),
                            BackgroundTransparency = 1,
                            Text = "",
                            Parent = menu,
                            ZIndex = 11
                        })
                        
                        local optionLabel = CustomUI.new("TextLabel", {
                            Size = UDim2.new(1, -8, 1, 0),
                            Position = UDim2.new(0, 4, 0, 0),
                            BackgroundTransparency = 1,
                            Text = val,
                            TextColor3 = theme.TextSecondary,
                            TextSize = 14,
                            Font = Enum.Font.Gotham,
                            TextXAlignment = "Left",
                            Parent = option,
                            ZIndex = 11
                        })
                        
                        option.MouseEnter:Connect(function()
                            option.BackgroundColor3 = theme.Primary
                            optionLabel.TextColor3 = theme.Text
                        end)
                        
                        option.MouseLeave:Connect(function()
                            option.BackgroundColor3 = Color3.new(1, 1, 1)
                            option.BackgroundTransparency = 1
                            optionLabel.TextColor3 = theme.TextSecondary
                        end)
                        
                        option.MouseButton1Click:Connect(function()
                            value = val
                            selectedLabel.Text = value
                            menu.Visible = false
                            
                            if config.Callback then
                                config.Callback(value)
                            end
                        end)
                        
                        table.insert(optionButtons, option)
                    end
                    
                    menu.Size = UDim2.new(0, 100, 0, #newValues * 32 + 8)
                end
                
                refreshOptions(values)
                
                box.MouseButton1Click:Connect(function()
                    menu.Visible = not menu.Visible
                end)
                
                -- 點擊其他地方關閉菜單
                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local pos = UserInputService:GetMouseLocation()
                        local boxPos = box.AbsolutePosition
                        local boxSize = box.AbsoluteSize
                        local menuPos = menu.AbsolutePosition
                        local menuSize = menu.AbsoluteSize
                        
                        local inBox = pos.X >= boxPos.X and pos.X <= boxPos.X + boxSize.X and
                                     pos.Y >= boxPos.Y and pos.Y <= boxPos.Y + boxSize.Y
                        local inMenu = menu.Visible and 
                                     pos.X >= menuPos.X and pos.X <= menuPos.X + menuSize.X and
                                     pos.Y >= menuPos.Y and pos.Y <= menuPos.Y + menuSize.Y
                        
                        if not inBox and not inMenu then
                            menu.Visible = false
                        end
                    end
                end)
                
                element.Set = function(_, newValue)
                    value = newValue
                    selectedLabel.Text = value
                end
                
                element.Refresh = function(_, newValues)
                    refreshOptions(newValues)
                end
                
            elseif elementType == "Input" then
                -- 輸入框
                element = CustomUI.new("Frame", {
                    Size = UDim2.new(1, 0, 0, 40),
                    BackgroundTransparency = 1,
                    Parent = content
                })
                
                -- 標題
                local title = CustomUI.new("TextLabel", {
                    Size = UDim2.new(1, -120, 1, 0),
                    Position = UDim2.new(0, 16, 0, 0),
                    BackgroundTransparency = 1,
                    Text = config.Title or "Input",
                    TextColor3 = theme.Text,
                    TextSize = 16,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = "Left",
                    Parent = element
                })
                
                -- 輸入框
                local input = CustomUI.new("TextBox", {
                    Size = UDim2.new(0, 120, 0, 32),
                    Position = UDim2.new(1, -136, 0.5, -16),
                    BackgroundColor3 = theme.Surface,
                    Text = config.Default or "",
                    PlaceholderText = config.Placeholder or "輸入...",
                    TextColor3 = theme.Text,
                    PlaceholderColor3 = theme.TextSecondary,
                    TextSize = 14,
                    Font = Enum.Font.Gotham,
                    ClearTextOnFocus = false,
                    Parent = element
                }, {
                    CustomUI.new("UICorner", { CornerRadius = UDim.new(0, 6) })
                })
                
                input.FocusLost:Connect(function(enterPressed)
                    if config.Callback then
                        config.Callback(input.Text)
                    end
                end)
                
                element.Set = function(_, newValue)
                    input.Text = newValue
                end
                
            elseif elementType == "Label" then
                -- 純文字標籤
                element = CustomUI.new("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text = config.Text or "",
                    TextColor3 = config.Color or theme.TextSecondary,
                    TextSize = config.TextSize or 14,
                    Font = config.Font or Enum.Font.Gotham,
                    TextXAlignment = config.Align or "Left",
                    Parent = content
                })
            end
            
            table.insert(self.Elements, element)
            return element
        end
        
        return tab
    end
    
    -- 可拖拽
    local dragging = false
    local dragOffset = Vector2.new()
    
    window.Topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragOffset = Vector2.new(
                input.Position.X - window.Frame.AbsolutePosition.X,
                input.Position.Y - window.Frame.AbsolutePosition.Y
            )
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = UserInputService:GetMouseLocation()
            window.Frame.Position = UDim2.new(0, pos.X - dragOffset.X, 0, pos.Y - dragOffset.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    -- 關閉功能
    function window:Destroy()
        screenGui:Destroy()
    end
    
    return window
end

-- 返回 UI 庫
return CustomUI
