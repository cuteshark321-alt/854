        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(1, -20, 0.5, -8),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6031090990",
        ImageColor3 = theme.Icon,
        Parent = box
    })
    
    local menu = CustomUI.new("Frame", {
        Size = UDim2.new(0, 120, 0, 0),
        Position = UDim2.new(1, -136, 1, 4),
        BackgroundTransparency = 1,
        Visible = false,
        Parent = frame,
        ZIndex = 10
    })
    
    local menuBg = CustomUI.newRoundFrame(10, "Squircle", {
        Size = UDim2.new(1, 0, 1, 0),
        ImageColor3 = theme.Dialog,
        ImageTransparency = 0,
        Parent = menu
    })
    
    local list = CustomUI.new("ScrollingFrame", {
        Size = UDim2.new(1, -8, 1, -8),
        Position = UDim2.new(0, 4, 0, 4),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = "Y",
        Parent = menuBg
    }, {
        CustomUI.new("UIListLayout", {
            Padding = UDim.new(0, 2),
            SortOrder = "LayoutOrder"
        })
    })
    
    local function refreshOptions(newValues)
        for _, child in pairs(list:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        for _, val in ipairs(newValues) do
            local option = CustomUI.new("TextButton", {
                Size = UDim2.new(1, 0, 0, 30),
                BackgroundTransparency = 1,
                Text = "",
                Parent = list
            })
            
            local optionLabel = CustomUI.new("TextLabel", {
                Size = UDim2.new(1, -16, 1, 0),
                Position = UDim2.new(0, 8, 0, 0),
                BackgroundTransparency = 1,
                Text = val,
                TextColor3 = theme.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = "Left",
                Parent = option
            })
            
            option.MouseEnter:Connect(function()
                option.BackgroundColor3 = theme.Button
                option.BackgroundTransparency = 0.9
            end)
            
            option.MouseLeave:Connect(function()
                option.BackgroundTransparency = 1
            end)
            
            option.MouseButton1Click:Connect(function()
                value = val
                selectedLabel.Text = value
                menu.Visible = false
                
                if config.Callback then
                    config.Callback(value)
                end
            end)
        end
        
        menu.Size = UDim2.new(0, 120, 0, math.min(#newValues * 32 + 8, 200))
    end
    
    refreshOptions(values)
    
    box.MouseButton1Click:Connect(function()
        menu.Visible = not menu.Visible
    end)
    
    frame.Refresh = function(_, newValues)
        refreshOptions(newValues)
    end
    
    frame.Set = function(_, newValue)
        value = newValue
        selectedLabel.Text = value
    end
    
    return frame
end

