    window.Tabs.List = CustomUI.new("ScrollingFrame", {
        Name = "TabList",
        Size = UDim2.new(1, -16, 1, -16),
        Position = UDim2.new(0, 8, 0, 8),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = "Y",
        Parent = window.Sidebar
    }, {
        CustomUI.new("UIListLayout", {
            Padding = UDim.new(0, 4),
            SortOrder = "LayoutOrder"
        })
    })
    
    -- 主要內容區域
    window.Content = CustomUI.new("Frame", {
        Name = "Content",
        Size = UDim2.new(1, -160, 1, -45),
        Position = UDim2.new(0, 160, 0, 45),
        BackgroundTransparency = 1,
        Parent = window.Frame
    })
    
    window.TabButtons = {}
    
    -- 添加標籤頁（完全複製 WindUI 風格）
    function window:AddTab(tabConfig)
        tabConfig = tabConfig or {}
        
        local tab = {}
        tab.Name = tabConfig.Title or "Tab"
        tab.Icon = tabConfig.Icon
        tab.Index = #self.TabButtons + 1
        tab.Elements = {}
        
        -- WindUI 風格的標籤按鈕
        local button = CustomUI.new("TextButton", {
            Name = "Tab_" .. tab.Name,
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1,
            Text = "",
            Parent = self.Tabs.List
        })
        
        local buttonBg = CustomUI.newRoundFrame(8, "Squircle", {
            Size = UDim2.new(1, 0, 1, 0),
            ImageColor3 = theme.TabBackground,
            ImageTransparency = 0.9,
            Parent = button
        })
        
        -- 圖標
        if tab.Icon then
            local icon = CustomUI.new("ImageLabel", {
                Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(0, 10, 0.5, -9),
                BackgroundTransparency = 1,
                Image = tab.Icon,
                ImageColor3 = theme.TabIcon,
                Parent = button
            })
            tab.IconObj = icon
        end
        
        -- 標籤文字
        local label = CustomUI.new("TextLabel", {
            Size = UDim2.new(1, tab.Icon and -38 or -16, 1, 0),
            Position = UDim2.new(0, tab.Icon and 36 or 8, 0, 0),
            BackgroundTransparency = 1,
            Text = tab.Name,
            TextColor3 = theme.TabTitle,
            TextSize = 15,
            Font = Enum.Font.Gotham,
            TextXAlignment = "Left",
            Parent = button
        })
        
        -- 標籤內容框架
        local content = CustomUI.new("ScrollingFrame", {
            Name = "TabContent_" .. tab.Name,
            Size = UDim2.new(1, -24, 1, -24),
            Position = UDim2.new(0, 12, 0, 12),
            BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 0,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = "Y",
            Parent = self.Content
        }, {
            CustomUI.new("UIListLayout", {
                Padding = UDim.new(0, 8),
                SortOrder = "LayoutOrder"
            })
        })
        
        tab.Content = content
        tab.Button = button
        tab.Label = label
        
        -- 按鈕點擊事件
        button.MouseButton1Click:Connect(function()
            for _, btn in pairs(self.TabButtons) do
                btn.Button.BackgroundTransparency = 1
                btn.Label.TextColor3 = theme.TabTitle
                if btn.IconObj then
                    btn.IconObj.ImageColor3 = theme.TabIcon
                end
                btn.Content.Visible = false
            end
            
            buttonBg.ImageTransparency = 0
            label.TextColor3 = theme.Text
            if tab.IconObj then
                tab.IconObj.ImageColor3 = theme.Text
            end
            content.Visible = true
            self.CurrentTab = tab
        end)
        
        button.MouseEnter:Connect(function()
            if self.CurrentTab ~= tab then
                buttonBg.ImageTransparency = 0.95
            end
        end)
        
        button.MouseLeave:Connect(function()
            if self.CurrentTab ~= tab then
                buttonBg.ImageTransparency = 0.9
            end
        end)
        
        table.insert(self.TabButtons, tab)
        
        -- 自動選中第一個
        if #self.TabButtons == 1 then
            buttonBg.ImageTransparency = 0
            label.TextColor3 = theme.Text
            if tab.IconObj then
                tab.IconObj.ImageColor3 = theme.Text
            end
            content.Visible = true
            self.CurrentTab = tab
        end
        
        -- 添加元素的方法（使用 WindUI 風格）
        function tab:AddElement(elementType, config)
            config = config or {}
            config.Parent = content
            
            local element
            if elementType == "Button" then
                element = CustomUI:CreateButton(config)
            elseif elementType == "Toggle" then
                element = CustomUI:CreateToggle(config)
            elseif elementType == "Slider" then
                element = CustomUI:CreateSlider(config)
            elseif elementType == "Input" then
                element = CustomUI:CreateInput(config)
            elseif elementType == "Dropdown" then
                element = CustomUI:CreateDropdown(config)
            elseif elementType == "Paragraph" or elementType == "Label" then
                element = CustomUI:CreateParagraph(config)
            end
            
            table.insert(tab.Elements, element)
            return element
        end
        
        return tab
    end
    
    -- 可拖拽
    local dragging = false
    local dragOffset = Vector2.new()
    
    window.Topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragOffset = Vector2.new(
                input.Position.X - window.Frame.AbsolutePosition.X,
                input.Position.Y - window.Frame.AbsolutePosition.Y
            )
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = UserInputService:GetMouseLocation()
            window.Frame.Position = UDim2.new(0, pos.X - dragOffset.X, 0, pos.Y - dragOffset.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return window
end

return CustomUI
