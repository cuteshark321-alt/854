-- WindUI 風格的滑塊
function CustomUI:CreateSlider(config)
    config = config or {}
    local theme = self.Themes[self.CurrentTheme or "Dark"]
    local min = config.Min or 0
    local max = config.Max or 100
    local value = config.Default or min
    
    local frame = CustomUI.new("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Parent = config.Parent
    })
    
    local title = CustomUI.new("TextLabel", {
        Size = UDim2.new(1, -80, 0, 20),
        Position = UDim2.new(0, 16, 0, 4),
        BackgroundTransparency = 1,
        Text = config.Title or "Slider",
        TextColor3 = theme.Text,
        TextSize = 16,
        Font = Enum.Font.Gotham,
        TextXAlignment = "Left",
        Parent = frame
    })
    
    local valueLabel = CustomUI.new("TextLabel", {
        Size = UDim2.new(0, 60, 0, 20),
        Position = UDim2.new(1, -76, 0, 4),
        BackgroundTransparency = 1,
        Text = tostring(value),
        TextColor3 = theme.Slider,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        Parent = frame
    })
    
    local track = CustomUI.new("Frame", {
        Size = UDim2.new(1, -32, 0, 4),
        Position = UDim2.new(0, 16, 0, 34),
        BackgroundColor3 = theme.Button,
        Parent = frame
    }, {
        CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
    })
    
    local fill = CustomUI.new("Frame", {
        Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = theme.Slider,
        Parent = track
    }, {
        CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
    })
    
    local knob = CustomUI.new("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new((value - min) / (max - min), -8, 0.5, -8),
        BackgroundColor3 = theme.White,
        Parent = track
    }, {
        CustomUI.new("UICorner", { CornerRadius = UDim.new(1, 0) })
    })
    
    local dragging = false
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local pos = UserInputService:GetMouseLocation()
            local trackPos = track.AbsolutePosition
            local trackSize = track.AbsoluteSize
            
            local percent = math.clamp((pos.X - trackPos.X) / trackSize.X, 0, 1)
            value = min + (max - min) * percent
            if config.Step then
                value = math.floor(value / config.Step + 0.5) * config.Step
                percent = (value - min) / (max - min)
            end
            
            fill.Size = UDim2.new(percent, 0, 1, 0)
            knob.Position = UDim2.new(percent, -8, 0.5, -8)
            valueLabel.Text = tostring(math.floor(value * 100) / 100)
            
            if config.Callback then
                config.Callback(value)
            end
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    frame.Set = function(_, newValue)
        value = newValue
        local percent = (value - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -8, 0.5, -8)
        valueLabel.Text = tostring(math.floor(value * 100) / 100)
    end
    
    return frame
end

