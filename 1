-- 創建 UI 元素
function CustomUI.new(class, props, children)
    local obj = Instance.new(class)
    
    for k, v in pairs(props or {}) do
        pcall(function()
            obj[k] = v
        end)
    end
    
    for _, child in pairs(children or {}) do
        if child then
            child.Parent = obj
        end
    end
    
    return obj
end

-- WindUI 風格的圓角框架
function CustomUI.newRoundFrame(radius, style, props, children)
    local frame = CustomUI.new("ImageLabel", {
        BackgroundTransparency = 1,
        Image = "rbxassetid://3570695787",
        ScaleType = "Slice",
        SliceCenter = Rect.new(radius, radius, radius, radius),
        SliceScale = 1,
    })
    
    for k, v in pairs(props or {}) do
        pcall(function()
            frame[k] = v
        end)
    end
    
    for _, child in pairs(children or {}) do
        child.Parent = frame
    end
    
    return frame
end

-- WindUI 風格的按鈕
function CustomUI:CreateButton(config)
    config = config or {}
    local theme = self.Themes[self.CurrentTheme or "Dark"]
    
    local button = CustomUI.new("TextButton", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1,
        Text = "",
        Parent = config.Parent
    })
    
    local bg = CustomUI.newRoundFrame(10, "Squircle", {
        Size = UDim2.new(1, 0, 1, 0),
        ImageColor3 = theme.Button,
        ImageTransparency = 0,
        Parent = button
    })
    
    local text = CustomUI.new("TextLabel", {
        Size = UDim2.new(1, -32, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Text = config.Title or "Button",
        TextColor3 = theme.Text,
        TextSize = 16,
        Font = Enum.Font.Gotham,
        TextXAlignment = "Left",
        Parent = button
    })
    
    button.MouseEnter:Connect(function()
