local Modules = ReplicatedStorage:WaitForChild("Modules")
local Net = Modules:WaitForChild("Net")
local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
local RegisterHit = Net:WaitForChild("RE/RegisterHit")

local AttackConfig = {
    Enabled = false,
    AttackDistance = 5000,
    AttackDelay = 0.3,
    AttackMobs = true,
    AttackPlayers = true,
}

local attackCounter = 0
local lastAttackTime = 0
local attackConnection = nil

-- 封包日誌
local packetLog = {}
local MAX_LOG = 50

local function addLog(type, args)
    local entry = {
        time = os.date("%H:%M:%S"),
        type = type,
        args = {}
    }
    for i, v in ipairs(args) do
        entry.args[i] = {
            value = tostring(v),
            type = typeof(v)
        }
    end
    table.insert(packetLog, entry)
    if #packetLog > MAX_LOG then
        table.remove(packetLog, 1)
    end
    updateLogDisplay()
end

local function GetAllTargets()
    local character = LocalPlayer.Character
    if not character then return {} end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return {} end
    local targets = {}
    if AttackConfig.AttackMobs then
        local enemies = workspace:FindFirstChild("Enemies")
        if enemies then
            for _, enemy in ipairs(enemies:GetChildren()) do
                if enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") then
                    local enemyRoot = enemy.HumanoidRootPart
                    if (rootPart.Position - enemyRoot.Position).Magnitude <= AttackConfig.AttackDistance then
                        table.insert(targets, {enemy, enemyRoot})
                    end
                end
            end
        end
    end
    if AttackConfig.AttackPlayers then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local targetChar = player.Character
                local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
                local targetHum = targetChar:FindFirstChild("Humanoid")
                if targetRoot and targetHum and targetHum.Health > 0 then
                    if (rootPart.Position - targetRoot.Position).Magnitude <= AttackConfig.AttackDistance then
                        table.insert(targets, {targetChar, targetRoot})
                    end
                end
            end
        end
    end
    return targets
end

local function Attack()
    local currentTime = tick()
    if (currentTime - lastAttackTime) < AttackConfig.AttackDelay then return end
    lastAttackTime = currentTime
    local character = LocalPlayer.Character
    if not character then return end
    local equipped = character:FindFirstChildOfClass("Tool")
    if not equipped then return end
    local targets = GetAllTargets()
    attackCounter = attackCounter + 1
    local step = attackCounter % 6
    if step == 0 then step = 6 end
    
    if step == 1 or step == 4 then
        -- 簡單格式
        local args = {AttackConfig.AttackDelay}
        RegisterHit:FireServer(AttackConfig.AttackDelay)
        RegisterAttack:FireServer(AttackConfig.AttackDelay)
        addLog("RegisterHit (簡單)", args)
        addLog("RegisterAttack (簡單)", args)
        
    elseif step == 2 or step == 5 then
        -- 4參數格式
        local targetRoot = #targets > 0 and targets[1][2] or nil
        if not targetRoot then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then targetRoot = hrp end
        end
        local randomId = tostring(math.random(10000, 99999))
        local hitArgs = {targetRoot, targets, {}, randomId}
        RegisterHit:FireServer(targetRoot, targets, {}, randomId)
        RegisterAttack:FireServer(targetRoot, targets, {}, randomId)
        addLog("RegisterHit (4參數)", hitArgs)
        addLog("RegisterAttack (4參數)", hitArgs)
        
    elseif step == 3 or step == 6 then
        -- 完整格式
        local targetRoot = #targets > 0 and targets[1][2] or nil
        if not targetRoot then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then targetRoot = hrp end
        end
        local hitArgs = {"TC)TcaourctNor", 11078161, targetRoot, targets}
        RegisterHit:FireServer("TC)TcaourctNor", 11078161, targetRoot, targets)
        RegisterAttack:FireServer("TC)TcaourctNor", 11078161, targetRoot, targets)
        addLog("RegisterHit (完整)", hitArgs)
        addLog("RegisterAttack (完整)", hitArgs)
    end
end

local function StartAttack()
    if attackConnection then attackConnection:Disconnect() end
    attackConnection = RunService.Heartbeat:Connect(function()
        pcall(Attack)
    end)
end

local function StopAttack()
    if attackConnection then
        attackConnection:Disconnect()
        attackConnection = nil
    end
end

