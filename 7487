function updateLogDisplay()
    local text = ""
    local start = math.max(1, #packetLog - 15) -- 只顯示最近15條
    for i = start, #packetLog do
        local entry = packetLog[i]
        local argsStr = ""
        for j, arg in ipairs(entry.args) do
            if j > 1 then argsStr = argsStr .. ", " end
            local val = arg.value
            if #val > 40 then val = val:sub(1, 40) .. "..." end
            argsStr = argsStr .. val
        end
        text = text .. string.format("[%s] %s: %s\n", entry.time, entry.type, argsStr)
    end
    LogText.Text = text
    LogFrame.CanvasSize = UDim2.new(0, 0, 0, LogContent.AbsoluteSize.Y + 10)
end

